# Railway / runtime
DATABASE_URL=sqlite+aiosqlite:///./data/addon.db
# For Railway Postgres use: postgresql+asyncpg://user:password@host:5432/dbname
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace_me
# Generate once locally with Telethon StringSession; do not use phone login in production.
TELEGRAM_SESSION_STRING=replace_me
# JSON array. category is tamil|telugu|malayalam|kannada|other|anime; original means original channel.
TELEGRAM_CHANNELS=[{"username":"my_tamil_channel","category":"tamil","original":true},{"username":"my_dubbed_channel","category":"other","original":false}]
# Comma separated; the client rotates keys on rate limits/errors.
TMDB_API_KEYS=key_one,key_two,key_three
TMDB_LANGUAGE=en-US
SCAN_INTERVAL_HOURS=4
TMDB_REFRESH_INTERVAL_HOURS=72
MAX_MESSAGES_PER_CHANNEL=0
MIN_MATCH_CONFIDENCE=0.58
PAGE_SIZE=100
