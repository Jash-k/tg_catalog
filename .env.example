# Database (Auto-provided by Railway PostgreSQL plugin)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Telegram
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION_STRING=your_session_string
TELEGRAM_CHANNELS=channel1,channel2,-1001234567890,https://t.me/channel4
# Comma-separated: usernames (with/without @), t.me links, or -100... channel IDs.
# For -100... IDs the session account MUST be a member of the channel.

# TMDB (single key OR multiple comma-separated keys - they rotate on 429/401)
TMDB_API_KEY=your_tmdb_api_key
TMDB_API_KEYS=
TMDB_ACCESS_TOKEN=your_tmdb_read_access_token
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_KEY_DISABLE_SECONDS=1800

# App
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
API_VERSION=v1

# Scanner Settings
SCAN_INTERVAL_HOURS=6
TMDB_SYNC_INTERVAL_DAYS=7
BATCH_SIZE=100
TMDB_RATE_LIMIT_DELAY=0.25
MIN_CONFIDENCE_SCORE=70

# Optional: API Key protection
API_SECRET_KEY=your_secret_for_protecting_api
# If set, all requests must include header: X-API-Key: value

# Optional: CORS (comma-separated origins, * = allow all)
ALLOWED_ORIGINS=*
